        "@radix-ui/react-slot": "^1.2.3",
        "@types/mdx": "^2.0.13",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "jose": "^6.2.2",
        "lucide-react": "^0.544.0",
        "next": "15.5.15",
        "next-themes": "^0.4.6",
        "react": "19.1.0",
